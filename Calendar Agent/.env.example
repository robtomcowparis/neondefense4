# --- Required ---

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar IDs. Find these in Google Calendar → Settings → each calendar → "Integrate calendar" → Calendar ID.
# "primary" works for the default calendar.
CLIENT_CALENDAR_ID=your-client-meetings@group.calendar.google.com
COURT_CALENDAR_ID=your-court-deadlines@group.calendar.google.com

# Password to access the app
APP_PASSWORD=changeme

# Session signing secret (any long random string)
SESSION_SECRET=replace-with-a-long-random-string

# Timezone (IANA name)
TIMEZONE=America/Los_Angeles

# --- Optional ---
# Default buffer minutes between events (guardrail)
BUFFER_MINUTES=15

# Earliest schedulable time of day (HH:MM, 24-hour)
WORK_DAY_START=09:30

# Latest schedulable time of day (HH:MM, 24-hour)
WORK_DAY_END=18:00

# Model. Defaults to claude-sonnet-4-6 for cost/speed; use claude-opus-4-5 for best reasoning.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Host/port
HOST=127.0.0.1
PORT=8000

# Set to true in production (HTTPS). Required for the session cookie to work
# across HTTPS. Leave false for local dev over http://127.0.0.1.
COOKIE_SECURE=false
